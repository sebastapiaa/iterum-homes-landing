# ============================================
# Iterum Homes Landing Page — Environment Variables
# Copy to .env.local and fill in
# ============================================

# === Email (Resend) ===
# Sign up free at resend.com
RESEND_API_KEY=

# Where lead notifications get sent (your inbox)
LEAD_NOTIFICATION_EMAIL=info@iterumhomes.com

# Email address notifications come FROM
# Must be a verified domain in Resend
LEAD_FROM_EMAIL=leads@iterumhomes.com

# === Public site config ===
NEXT_PUBLIC_SITE_URL=https://iterumhomes.com

# === Analytics (optional) ===
NEXT_PUBLIC_GA_MEASUREMENT_ID=
